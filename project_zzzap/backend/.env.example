# Zzzap! Backend Configuration
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/zzzap
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zzzap
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT Secret (CHANGE IN PRODUCTION!)
JWT_SECRET=zzzap-super-secret-key-change-this-in-production

# File Upload (S3 or local)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# SMS Provider (Twilio/Firebase)
SMS_PROVIDER=firebase
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Payment Gateway (Kaspi/Stripe)
PAYMENT_PROVIDER=kaspi
KASPI_MERCHANT_ID=
KASPI_SECRET_KEY=

# CDN (for video/images)
CDN_URL=https://cdn.zzzap.app
AWS_S3_BUCKET=zzzap-media
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
